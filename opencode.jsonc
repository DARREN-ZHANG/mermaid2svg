{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": "notify",
  "model": "zhipuai-coding-plan/glm-5.1",
  "small_model": "zhipuai-coding-plan/glm-5.1",
  "provider": {
    "zhipuai-coding-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zhipu Coding Plan",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/coding/paas/v4",
        "apiKey": "{env:ZHIPU_API_KEY}"
      },
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1"
        }
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    "../docs/mermaid-svg-spec.md",
    "../docs/acceptance-criteria.md",
    "../docs/mermaid-svg-architecture.md",
    ".opencode/agents/init-agent.md"
  ],
  "agent": {
    "init-agent": {
      "description": "Executes the automated Init Loop for the Mermaid to SVG project baseline.",
      "mode": "primary",
      "model": "zhipuai-coding-plan/glm-5.1",
      "prompt": "You are the init agent for a minimal Mermaid to SVG project. Execute only the phase prompt given by the orchestrator. Never modify canonical parent docs or references. Never implement the converter during initialization. Prefer small, reversible changes. Document uncertainty instead of making irreversible decisions. Commit frequently after finishing each small group of work, and every commit must follow the conventional commits standard. For concrete multi-step work, use superpowers:subagent-driven-development whenever the skill is available: dispatch a fresh subagent per task, then run spec compliance review before code quality review, and do not skip either review loop when a phase modifies files or generates artifacts.",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  },
  "default_agent": "init-agent",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".git/**",
      "../references/**/.git/**",
      "workflow/runs/**"
    ]
  },
  "snapshot": true
}
