doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Mermaid → SVG
    link(rel="stylesheet" href="https://registry.npmmirror.com/18s/0.2.24/files/_.css")
    link(rel="stylesheet" href="./style.css")
    link(rel="stylesheet" href="./theme.css")
  body
    c-vs
      header
        .header-controls
          .theme-switcher#theme-switcher
          c-i18n
          a.BtnC.github-link(href="https://github.com/DARREN-ZHANG/mermaid2svg" target="_blank" aria-label="GitHub Repository")
            i.Ico
              include svg/github.svg
      main
        .container
          .header-main
            h1
              a#ui-title(href="https://github.com/DARREN-ZHANG/mermaid2svg" target="_blank") Mermaid → SVG
            p#ui-subtitle.subtitle Browser-side Mermaid to SVG converter
          .main-grid
            .card.usage-card.Lg
              .card-header
                h2#ui-usage-title Usage
              pre.code-block
                code#ui-usage-code

            .card.benchmark-card.Lg
              .benchmark-header
                h2#ui-benchmark-title Size Comparison
                span#ui-benchmark-tip.tip performance proxy, not a runtime benchmark
              #size-chart.size-chart-container

            .card.editor-card.Lg
              .editor-header
                .editor-title-row
                  h2#ui-editor-title Interactive Editor
                p#ui-editor-tip.tip Enter Mermaid source text to render SVG
              .editor-body
                textarea#mermaid-input(placeholder="Enter Mermaid source here...")
                .svg-preview-wrap
                  #svg-preview
                  .svg-actions
              #render-status.render-status
          .examples-section
            h2#ui-examples-title Examples
            #examples-grid.examples-grid
      script(type="module" src="./index.js")
