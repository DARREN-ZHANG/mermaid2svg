@import './webc/I18n/_.styl'
@import './webc/Lg/_.styl'
@import './webc/Scroll/_.styl'

:root
  --accent-color #2563eb
  --accent-glow #2563eb14
  --accent-gradient linear-gradient(135deg, #3b82f6 0, #2563eb 100%)
  --accent-hover #1d4ed8
  --bg-color #f8fafc
  --border-color #e2e8f0
  --card-bg #ffffff
  --success-color #10b981
  --text-color #0f172a
  --text-muted #64748b

body, input, select, button, textarea
  font-family t, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif

html, body
  height 100%
  overflow hidden

html
  scroll-behavior smooth

body
  background #ffffff url('./svg/bg.svg') no-repeat center / cover
  background-attachment fixed
  box-sizing border-box
  color var(--text-color)
  display flex
  flex-direction column
  margin 0
  padding 0

header
  position fixed
  right 24px
  top 24px
  z-index 100

.header-controls
  align-items center
  display flex
  gap 16px

c-i18n
  display flex

.header-controls .BtnC
  align-items center
  display flex
  justify-content center

  .Ico
    align-items center
    display flex
    justify-content center
    position relative

  svg
    color var(--text-muted)
    fill currentColor
    height 20px
    transition color 0.2s
    width 20px

  &:hover svg
    color var(--text-color)

.header-main
  align-items center
  display flex
  flex-direction column
  gap 12px
  margin 31px auto 56px
  max-width 800px
  text-align center

  h1
    font-size 44px
    font-variation-settings 'wght' 250
    font-weight 250
    letter-spacing -1.2px
    margin 0

    a
      color var(--text-color)
      text-decoration none
      transition opacity 0.2s

      &:hover
        opacity 0.85

  .subtitle
    color var(--text-muted)
    font-size 18px
    font-weight 400
    line-height 1.5
    margin 0
    text-align center

.subtitle a
  color var(--accent-color)
  font-weight 600
  text-decoration none
  transition color 0.2s

  &:hover
    color var(--accent-hover)
    text-decoration underline

main
  display flex
  flex 1
  justify-content center
  padding 24px

.container
  display flex
  flex-direction column
  gap 40px
  max-width 1200px
  width 100%

.card
  border-radius 24px
  box-shadow 0 4px 6px -1px #0000000d, 0 2px 4px -1px #00000008
  display flex
  flex-direction column
  padding 32px
  position relative
  z-index 1

  h2
    color var(--text-color)
    font-size 22px
    font-weight 700
    margin-bottom 8px
    margin-top 0

.card-header
  align-items center
  display flex
  justify-content space-between
  margin-bottom 12px

  h2
    margin 0

.tag
  align-items center
  background-color var(--accent-glow)
  border 1px solid #2563eb26
  border-radius 9999px
  box-shadow 0 1px 2px #00000005
  color var(--accent-color)
  display inline-flex
  font-size 13px
  font-weight 600
  padding 6px 14px
  text-decoration none
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  &:hover
    background-color var(--accent-color)
    border-color var(--accent-color)
    box-shadow 0 4px 6px -1px #2563eb26
    color #ffffff
    transform translateY(-1px)

// ===== 编辑器卡片 =====

.editor-card
  display flex
  flex-direction column
  gap 20px
  grid-column 1 / -1

.editor-header
  display flex
  flex-direction column

  h2
    margin-bottom 4px

.editor-title-row
  align-items center
  display flex
  flex-wrap wrap
  gap 12px
  justify-content space-between

  h2
    margin 0

.tip
  color var(--text-muted)
  font-size 15px
  font-weight 300
  margin 0

.editor-body
  display flex
  gap 20px
  width 100%

#mermaid-input
  background-color #f8fafc
  border 1px solid var(--border-color)
  border-radius 10px
  box-sizing border-box
  color var(--text-color)
  field-sizing content
  flex 1
  font-family c, monospace
  font-size 18px
  line-height 1.6
  min-height 200px
  min-width 0
  outline none
  padding 20px
  resize none
  transition border-color 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease
  width 100%

  &:focus
    background-color #ffffff
    border-color var(--accent-color)
    box-shadow 0 0 0 3px var(--accent-glow)

.svg-preview-wrap
  display flex
  flex 1
  flex-direction column
  gap 8px
  min-width 0
  position relative

#svg-preview
  align-items center
  background-color #f8fafc
  background-image radial-gradient(var(--border-color) 1.2px, transparent 1.2px)
  background-size 16px 16px
  border 1px solid var(--border-color)
  border-radius 16px
  box-shadow inset 0 2px 6px #00000005
  display flex
  flex 1
  justify-content center
  min-height 200px
  overflow auto
  padding 32px

  svg
    border-radius 10px
    display block
    height auto
    max-width 100%
    transition opacity 0.2s

  foreignObject
    overflow visible

  .nodeLabel, .edgeLabel, .labelBkg
    font-family 'trebuchet ms', verdana, arial, sans-serif

.render-status
  color var(--text-muted)
  font-size 14px
  margin-top 16px
  min-height 20px
  transition color 0.2s
  width 100%

  &.error
    background-color #fee2e2
    border 1px solid #fecaca
    border-radius 12px
    color #dc2626
    padding 12px 18px

.svg-actions
  align-items center
  display flex
  gap 10px
  position absolute
  right 16px
  top 16px
  z-index 10

  &.is-hidden
    display none

  .Btn
    background-color #ffffffd9
    border 1px solid var(--border-color)
    box-shadow 0 2px 6px #0000000d
    font-size 12px
    --btnPadding 6px 14px
    --btnRadius 16px

    &::after
      display none

    &:hover
      box-shadow 0 4px 12px #00000014

// ===== 示例图库 =====

.examples-section
  display flex
  flex-direction column
  gap 24px

  h2
    color var(--text-color)
    font-size 24px
    font-weight 700
    margin 0

.examples-grid
  display grid
  gap 24px
  grid-template-columns repeat(2, 1fr)
  width 100%

  .example-card
    border-radius 16px
    box-shadow 0 4px 6px -1px #0000000d, 0 2px 4px -1px #00000008
    box-sizing border-box
    cursor pointer
    display flex
    flex-direction column
    gap 12px
    height 100%
    padding 24px
    position relative
    transition transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s

    &:hover
      box-shadow 0 12px 20px -3px #00000014, 0 4px 6px -2px #00000008
      transform translateY(-4px)

    h3
      color var(--text-color)
      font-size 18px
      font-weight 600
      margin 0

    .mermaid-code
      background-color var(--bg-color)
      border 1px solid var(--border-color)
      border-radius 8px
      color var(--text-muted)
      font-family c, monospace
      font-size 14px
      overflow-x auto
      padding 12px 16px
      white-space pre-wrap
      word-break break-all

    .rendered-svg
      align-items center
      background-color #f8fafc
      border 1px solid var(--border-color)
      border-radius 10px
      display flex
      flex 1
      justify-content center
      min-height 100px
      overflow hidden
      padding 32px

      svg
        border-radius 8px
        display block
        height auto
        max-width 100%

      foreignObject
        overflow visible

      .nodeLabel, .edgeLabel, .labelBkg
        font-family 'trebuchet ms', verdana, arial, sans-serif

// ===== 代码块 =====

.code-block
  background-color #f8fafc
  border 1px solid var(--border-color)
  border-radius 10px
  margin 0
  padding 24px
  white-space pre-wrap
  word-wrap break-word

  code
    color #1e293b
    font-family c, monospace
    font-size 14px
    font-weight 300
    line-height 1.6

// ===== 主网格布局 =====

.main-grid
  display grid
  gap 40px
  grid-template-columns 1fr 360px
  width 100%

// ===== 对比图占位 =====

.benchmark-card
  display flex
  flex-direction column

.benchmark-header
  align-items baseline
  display flex
  flex-wrap wrap
  gap 8px
  justify-content space-between
  margin-bottom 12px

  h2
    color var(--text-color)
    font-size 22px
    font-weight 700
    margin 0

  .tip
    color var(--text-muted)
    font-size 14px

.size-chart-container
  svg
    height auto
    width 100%

// ===== 主题切换器 (Dropdown) =====

.theme-switcher
  display inline-block
  position relative

.theme-trigger
  align-items center
  background-color #ffffff
  border 1px solid var(--border-color)
  border-radius 9999px
  box-shadow 0 1px 2px #0000000a
  color var(--text-color)
  cursor pointer
  display inline-flex
  font-size 13px
  font-weight 500
  gap 8px
  height 36px
  padding 0 16px
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  white-space nowrap

  &:hover
    border-color var(--accent-color)
    color var(--accent-color)
    transform translateY(-1px)

.theme-trigger-arrow
  border-left 4px solid transparent
  border-right 4px solid transparent
  border-top 4px solid currentColor
  display inline-block
  height 0
  margin-left 2px
  transition transform 0.2s
  width 0

.theme-dropdown
  backdrop-filter blur(16px) saturate(160%)
  background linear-gradient(180deg, #fffffff2, #ffffffe6)
  border 1px solid var(--border-color)
  border-radius 16px
  box-shadow 0 10px 30px #0000001a, 0 1px 3px #0000000d
  box-sizing border-box
  display flex
  flex-direction column
  gap 2px
  opacity 0
  padding 6px
  pointer-events none
  position absolute
  right 0
  top calc(100% + 8px)
  transform translateY(-10px) scale(0.95)
  transition all 0.2s cubic-bezier(0.16, 1, 0.3, 1)
  width 180px
  z-index 200

  &.is-open
    opacity 1
    pointer-events auto
    transform translateY(0) scale(1)

.theme-dropdown-item
  align-items center
  background none
  border none
  border-radius 10px
  color var(--text-color)
  cursor pointer
  display flex
  font-size 13px
  font-weight 500
  gap 8px
  padding 8px 12px
  text-align left
  transition all 0.15s ease
  width 100%

  &:hover
    background-color #0000000a
    color var(--accent-color)

  &.active
    background-color var(--accent-color)
    color #ffffff

    .theme-swatch
      box-shadow 0 0 0 1px #ffffff80

.theme-swatch
  border 1px solid currentColor
  border-radius 9999px
  box-sizing border-box
  display inline-block
  flex-shrink 0
  height 12px
  width 12px

  &.is-default
    background conic-gradient(#ff453a, #ff9f0a, #ffd60a, #30d158, #0a84ff, #5e5ce6, #ff453a)
    border none

// ===== 响应式 =====

@media (max-width 768px)
  header
    right 16px
    top 16px

  .header-main
    margin 46px auto 0

    h1
      font-size 32px

  .header-content
    align-items center
    flex-direction column
    gap 6px
    text-align center

  .subtitle
    border-left none
    padding-left 0

  .main-grid
    display flex
    flex-direction column

  .usage-card
    order 1

  .benchmark-card
    order 2

  .editor-card
    order 3

  .editor-body
    flex-direction column

  .examples-grid
    grid-template-columns 1fr